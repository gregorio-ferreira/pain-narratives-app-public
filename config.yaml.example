# Configuration file for AINarratives Application
# Copy this file to config.yaml and fill in your values
# config.yaml is gitignored and should contain your actual credentials

models:
  default_model: gpt-5-mini
  default_temperature: 1.0
  default_top_p: 1.0
  default_max_tokens: 8000
  translation_model: gpt-5-mini
  translation_temperature: 1.0
  translation_max_tokens: 8000

openai:
  # Get your API key from: https://platform.openai.com/api-keys
  api_key_pain_narratives: "YOUR_OPENAI_API_KEY"
  org_id: "YOUR_OPENAI_ORG_ID"

# AWS Bedrock — required for the revision experiments (DeepSeek-R1, Claude Sonnet 4.5).
# See docs/revision/AWS_BEDROCK_SETUP.md for how to obtain the API key.
# The api_key is a Bedrock-scoped bearer token; boto3 reads it from the
# AWS_BEARER_TOKEN_BEDROCK env var, which the app populates from this config.
bedrock:
  api_key: "YOUR_BEDROCK_API_KEY"
  default_region: us-east-1

# Database configuration - matches docker-compose.yml defaults
pg-prod:
  password: "pain_narratives_dev"
  host: "localhost"  # Use 'localhost' when running app locally, 'postgres' if running app in Docker
  database: "pain_narratives"
  user: "pain_narratives"
  port: 5432

app:
  data_root_path: "./data"
  environment: development
  streamlit_server_port: 8501
  streamlit_server_address: 0.0.0.0
